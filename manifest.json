{
    "manifest_version": 3,
    "name": "Habitify",
    "version": "0.0.1",
    "description": "Build habits by blocking distracting websites during scheduled time",

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "permissions": [
        "storage",
        "alarms",
        "tabs",
        "notifications"
    ],

    "action" : {
        "default_popup" : "popup.html"
    },

    "background" : {
        "service_worker" : "background.js"
    },

    "web_accessible_resources": [{
    "resources": ["blocked.html"],
    "matches": ["<all_urls>"]
  }]
}